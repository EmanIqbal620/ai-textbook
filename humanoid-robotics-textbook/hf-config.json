{
  "huggingface": {
    "organization": "humanoid-robotics",
    "space_name": "humanoid-robotics-textbook",
    "space_type": "static",
    "license": "mit",
    "visibility": "public"
  },
  "backend": {
    "deployment": "inference-endpoint",
    "model": "mistralai/Mistral-7B-Instruct-v0.2",
    "embeddings": "sentence-transformers/all-MiniLM-L6-v2",
    "vector_store": "qdrant"
  },
  "frontend": {
    "build_command": "npm run build",
    "output_directory": "build",
    "node_version": "20"
  },
  "github": {
    "auto_deploy": true,
    "branch": "main",
    "ci_enabled": true
  },
  "chatbot": {
    "api_endpoint": "/api/chat",
    "max_tokens": 500,
    "temperature": 0.7,
    "stream": true
  }
}
