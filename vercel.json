{
  "version": 2,
  "builds": [
    {
      "src": "humanoid-robotics-textbook/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "api/chat.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11",
        "maxDuration": 30,
        "memory": 1024
      }
    },
    {
      "src": "api/health.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/humanoid-robotics-textbook/$1"
    }
  ],
  "crons": []
}
