# Vercel Environment Variables Example
# 
# These are NOT for your backend - only for Vercel frontend if needed
# Add these in Vercel Dashboard: Settings → Environment Variables

# Backend API URL (Your Hugging Face backend)
# Example: https://your-username-humanoid-robotics-backend.hf.space
NEXT_PUBLIC_API_BASE_URL=https://your-username-humanoid-robotics-backend.hf.space
